# Twilio credentials (from twilio.com/console)
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Whitelist of phone numbers allowed to send SMS messages to your Twilio number.
# Comma-separated list of E.164 formatted phone numbers.
# Example: +15551234567,+15557654321
ALLOWED_PHONE_NUMBERS=+15551234567,+15557654321

# Smee.io channel Twilio posts to, and where it gets forwarded locally.
# Get a channel URL at https://smee.io.
SMEE_URL=https://smee.io/your-channel
TARGET_URL=http://localhost:5000/sms

# URL used to validate the Twilio request signature. Usually the same as
# SMEE_URL, since that's the public URL Twilio actually calls.
WEBHOOK_FORWARDING_URL=https://smee.io/your-channel

# ProPresenter local API (default port is 1025)
PROPRESENTER_HOST=localhost
PROPRESENTER_PORT=1025

# The exact name of the ProPresenter Message to update and trigger
PROPRESENTER_MESSAGE_NAME=SMS Notification

# Token name inside the message template that receives the SMS text
# e.g. if your message has {message} in it, set this to: message
PROPRESENTER_TOKEN_NAME=message

# Flask server config
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Set to "false" only for local testing (default: true)
VALIDATE_TWILIO_SIGNATURE=true

# Message regular expression pattern to match against incoming SMS messages.
# If the message matches, it will be forwarded to ProPresenter.
# If the message does not match, it will be ignored.
# Example: ^(Hello|Hi|Hey)\s+ProPresenter$
MESSAGE_REGEX_PATTERN="^[A-Z0-9]{4}$"
